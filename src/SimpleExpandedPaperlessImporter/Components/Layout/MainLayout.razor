@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="layout">
    <nav class="sidebar">
        <div class="logo">📄 Simple Expanded Paperless Importer</div>
        <NavLink href="/" Match="NavLinkMatch.All">🏠 Dashboard</NavLink>
        <NavLink href="/upload">📤 Upload</NavLink>
        <NavLink href="/correspondents">🗂️ Korrespondenten</NavLink>
        <NavLink href="/errors">⚠️ Fehler</NavLink>
        <NavLink href="/settings">⚙️ Einstellungen</NavLink>
        <NavLink href="/change-password">🔑 Passwort ändern</NavLink>
        <div class="sidebar-spacer"></div>
        <AuthorizeView>
            <Authorized>
                <div class="sidebar-user">👤 @context.User.Identity?.Name</div>
                <form method="post" action="/logout">
                    <AntiforgeryToken />
                    <button type="submit" class="logout-btn">🚪 Abmelden</button>
                </form>
            </Authorized>
        </AuthorizeView>
    </nav>
    <main class="content">
        @Body
    </main>
</div>
