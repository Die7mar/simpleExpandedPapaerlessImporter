@page "/upload"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using Microsoft.EntityFrameworkCore
@using SimpleExpandedPaperlessImporter.Data
@inject PaperlessApiService PaperlessApi
@inject IOptionsMonitor<PaperlessSettings> Options
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ILogger<Upload> Logger

<PageTitle>Upload – Simple Expanded Paperless Importer</PageTitle>

<h1>📤 Dokument hochladen</h1>
<p class="hint" style="margin-bottom:1.5rem">Dokumente direkt über das Webinterface in Paperless hochladen.</p>

@if (_messages.Count > 0)
{
    <div style="margin-bottom:1rem">
        @foreach (var (msg, ok) in _messages)
        {
            <div class="@(ok ? "alert-success" : "alert-error")">@msg</div>
        }
    </div>
}

<div class="card" style="max-width:600px; padding:1.5rem; background:#fff; border-radius:10px; box-shadow:0 1px 4px rgba(0,0,0,.08)">
    <div class="login-field" style="margin-bottom:1rem">
        <label>Korrespondent (optional)</label>
        <select class="form-input" value="@_selectedCorrespondentId"
                @onchange="OnCorrespondentChanged">
            <option value="0">– Kein Korrespondent –</option>
            @foreach (var c in _correspondents)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>

    <div class="login-field" style="margin-bottom:1rem">
        <label>Tags</label>
        <p class="hint" style="margin-bottom:0.4rem">
            Automatisch gesetzt durch Korrespondent &amp; globale Standard-Tags. Manuell anpassbar.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.3rem">
            @foreach (var tag in _allTags)
            {
                var tagId = tag.Id;
                var isAuto = _autoTagIds.Contains(tagId);
                <label style="display:flex; align-items:center; gap:0.25rem; font-size:0.85rem; cursor:pointer;
                              background:@(_selectedTagIds.Contains(tagId) ? "#ebf8ff" : "#f7fafc");
                              border:1px solid @(_selectedTagIds.Contains(tagId) ? "#63b3ed" : "#e2e8f0");
                              border-radius:20px; padding:0.2rem 0.65rem; transition:all 0.1s"
                      title="@(isAuto ? "Automatisch durch Korrespondent/Standard-Tags" : "")">
                    <input type="checkbox"
                           style="display:none"
                           checked="@_selectedTagIds.Contains(tagId)"
                           @onchange="e => ToggleTag(tagId, (bool)e.Value!)" />
                    @tag.Name@(isAuto ? " ✦" : "")
                </label>
            }
        </div>
        @if (_allTags.Count == 0)
        {
            <p class="hint">Keine Tags in Paperless gefunden.</p>
        }
    </div>

    <div class="login-field" style="margin-bottom:1.25rem">
        <label>Dateien auswählen (PDF, JPG, PNG, TIF, EML, TXT)</label>
        <InputFile OnChange="OnFilesSelected" multiple accept=".pdf,.jpg,.jpeg,.png,.tif,.tiff,.eml,.txt"
                   class="form-input" style="padding:0.3rem" />
    </div>

    <button class="btn-save" @onclick="DoUpload" disabled="@(_loading || _files.Count == 0)">
        @(_loading ? "Hochladen …" : $"📤 {_files.Count} Datei(en) hochladen")
    </button>
</div>

@code {
    private List<IBrowserFile> _files = [];
    private List<PaperlessCorrespondent> _correspondents = [];
    private List<PaperlessTag> _allTags = [];
    // Tags currently checked (user may override)
    private HashSet<int> _selectedTagIds = [];
    // Tags that were auto-applied (shown with ✦)
    private HashSet<int> _autoTagIds = [];
    // Stored per-correspondent tags from DB
    private Dictionary<int, List<int>> _correspondentTagMap = [];
    private int _selectedCorrespondentId;
    private bool _loading;
    private List<(string Msg, bool Ok)> _messages = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _correspondents = await PaperlessApi.GetAllCorrespondentsAsync();
            _allTags        = await PaperlessApi.GetAllTagsAsync();

            // Load all CorrespondentSettings from DB
            await using var db = await DbFactory.CreateDbContextAsync();
            var settings = await db.CorrespondentSettings.ToListAsync();
            _correspondentTagMap = settings.ToDictionary(
                s => s.CorrespondentId,
                s => s.GetTagIds());
        }
        catch (Exception ex)
        {
            _messages.Add(($"⚠️ Verbindung fehlgeschlagen: {ex.Message}", false));
        }

        // Pre-select global default tags
        ApplyAutoTags(null);
    }

    private void OnCorrespondentChanged(ChangeEventArgs e)
    {
        _selectedCorrespondentId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        ApplyAutoTags(_selectedCorrespondentId == 0 ? null : _selectedCorrespondentId);
    }

    /// <summary>
    /// Recalculates auto-tags (global defaults + correspondent-specific) and
    /// merges them into _selectedTagIds, removing only previously auto-applied tags
    /// that were not manually added.
    /// </summary>
    private void ApplyAutoTags(int? correspondentId)
    {
        // Remove previously auto-applied tags (unless user explicitly kept them via toggle)
        _selectedTagIds.ExceptWith(_autoTagIds);
        _autoTagIds.Clear();

        // Global default tags by name
        var defaultNames = Options.CurrentValue.DefaultTags;
        foreach (var name in defaultNames)
        {
            var tag = _allTags.FirstOrDefault(t =>
                string.Equals(t.Name, name, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(t.Slug, name, StringComparison.OrdinalIgnoreCase));
            if (tag is not null) _autoTagIds.Add(tag.Id);
        }

        // Per-correspondent tags from DB
        if (correspondentId.HasValue &&
            _correspondentTagMap.TryGetValue(correspondentId.Value, out var cTags))
        {
            foreach (var id in cTags) _autoTagIds.Add(id);
        }

        // Apply auto-tags
        _selectedTagIds.UnionWith(_autoTagIds);
    }

    private void OnFilesSelected(InputFileChangeEventArgs e) =>
        _files = [.. e.GetMultipleFiles(20)];

    private void ToggleTag(int id, bool on)
    {
        if (on)
        {
            _selectedTagIds.Add(id);
            // If user manually re-checks an auto-tag, keep it as auto
        }
        else
        {
            _selectedTagIds.Remove(id);
            // Remove from auto set so ApplyAutoTags won't re-add it next time
            _autoTagIds.Remove(id);
        }
    }

    private async Task DoUpload()
    {
        if (_files.Count == 0) return;

        _loading  = true;
        _messages = [];
        StateHasChanged();

        var tempDir = Path.Combine(Path.GetTempPath(), "sepi-upload");
        Directory.CreateDirectory(tempDir);

        var correspondentId = _selectedCorrespondentId == 0 ? (int?)null : _selectedCorrespondentId;
        var tagIds = _selectedTagIds.ToList();

        foreach (var file in _files)
        {
            var safeName = Path.GetFileName(file.Name);
            var tempPath = Path.Combine(tempDir, $"{Guid.NewGuid():N}_{safeName}");

            try
            {
                await using (var fs = File.Create(tempPath))
                await using (var stream = file.OpenReadStream(maxAllowedSize: 200 * 1024 * 1024))
                    await stream.CopyToAsync(fs);

                var taskId = await PaperlessApi.UploadDocumentAsync(
                    tempPath, safeName, correspondentId, tagIds);

                _messages.Add(($"✅ {safeName} → Paperless Task: {taskId}", true));
            }
            catch (Exception ex)
            {
                _messages.Add(($"❌ {safeName}: {ex.Message}", false));
                Logger.LogError(ex, "Web upload failed for '{File}'", safeName);
            }
            finally
            {
                if (File.Exists(tempPath)) File.Delete(tempPath);
            }
        }

        _files   = [];
        _loading = false;
    }
}
