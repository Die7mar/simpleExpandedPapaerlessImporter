@page "/correspondents"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SimpleExpandedPaperlessImporter.Data
@inject PaperlessApiService PaperlessApi
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Korrespondenten – Simple Expanded Paperless Importer</PageTitle>

<h1>🗂️ Korrespondenten & Tags</h1>
<p class="hint" style="margin-bottom:1.5rem">Weise jedem Korrespondenten individuelle Tags zu. Diese werden beim Import zusätzlich zu den globalen Standard-Tags gesetzt.</p>

@if (_loading)
{
    <p>⏳ Lade Daten …</p>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="alert-error">@_error</div>
}
else
{
    @if (!string.IsNullOrEmpty(_saveMsg))
    {
        <div class="alert-success" style="margin-bottom:1rem">@_saveMsg</div>
    }

    <div style="display:flex; flex-direction:column; gap:1rem; max-width:720px">
        @foreach (var c in _correspondents)
        {
            var cId = c.Id;
            var selected = _settings.TryGetValue(cId, out var s) ? s : new HashSet<int>();

            <div class="card" style="background:#fff; border-radius:10px; padding:1.25rem 1.5rem; box-shadow:0 1px 4px rgba(0,0,0,.08)">
                <div style="font-weight:700; margin-bottom:0.75rem">👤 @c.Name</div>
                <div style="display:flex; flex-wrap:wrap; gap:0.4rem">
                    @foreach (var tag in _allTags)
                    {
                        var tagId = tag.Id;
                        <label style="display:flex; align-items:center; gap:0.25rem; font-size:0.85rem; cursor:pointer;
                                      background:@(selected.Contains(tagId) ? "#ebf8ff" : "#f7fafc");
                                      border:1px solid @(selected.Contains(tagId) ? "#63b3ed" : "#e2e8f0");
                                      border-radius:20px; padding:0.2rem 0.65rem; transition:all 0.1s">
                            <input type="checkbox"
                                   style="display:none"
                                   checked="@selected.Contains(tagId)"
                                   @onchange="e => ToggleTag(cId, tagId, (bool)e.Value!)" />
                            @tag.Name
                        </label>
                    }
                </div>
            </div>
        }
    </div>

    <div class="form-actions" style="margin-top:1.5rem">
        <button class="btn-save" @onclick="SaveAll" disabled="@_saving">
            @(_saving ? "Speichern …" : "💾 Alle Tags speichern")
        </button>
    </div>
}

@code {
    private List<PaperlessCorrespondent> _correspondents = [];
    private List<PaperlessTag> _allTags = [];
    // key = correspondentId, value = selected tag IDs
    private Dictionary<int, HashSet<int>> _settings = [];
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private string? _saveMsg;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _correspondents = await PaperlessApi.GetAllCorrespondentsAsync();
            _allTags        = await PaperlessApi.GetAllTagsAsync();

            await using var db = await DbFactory.CreateDbContextAsync();
            var stored = await db.CorrespondentSettings.ToListAsync();

            _settings = _correspondents.ToDictionary(
                c => c.Id,
                c =>
                {
                    var entry = stored.FirstOrDefault(s => s.CorrespondentId == c.Id);
                    return entry is not null
                        ? new HashSet<int>(entry.GetTagIds())
                        : new HashSet<int>();
                });
        }
        catch (Exception ex)
        {
            _error = $"Fehler beim Laden: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleTag(int correspondentId, int tagId, bool on)
    {
        if (!_settings.TryGetValue(correspondentId, out var set))
        {
            set = [];
            _settings[correspondentId] = set;
        }
        if (on) set.Add(tagId);
        else    set.Remove(tagId);
    }

    private async Task SaveAll()
    {
        _saving  = true;
        _saveMsg = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            foreach (var (cId, tagIds) in _settings)
            {
                var entity = await db.CorrespondentSettings.FindAsync(cId);
                if (entity is null)
                {
                    entity = new Data.CorrespondentSettings { CorrespondentId = cId };
                    entity.SetTagIds(tagIds);
                    db.CorrespondentSettings.Add(entity);
                }
                else
                {
                    entity.SetTagIds(tagIds);
                    db.CorrespondentSettings.Update(entity);
                }
            }

            await db.SaveChangesAsync();
            _saveMsg = "✅ Tags erfolgreich gespeichert!";
        }
        catch (Exception ex)
        {
            _error = $"Fehler beim Speichern: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
