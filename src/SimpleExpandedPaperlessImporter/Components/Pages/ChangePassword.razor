@page "/change-password"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Passwort ändern – Simple Expanded Paperless Importer</PageTitle>

<h1>🔑 Passwort ändern</h1>

@if (_success)
{
    <div class="alert-success">
        ✅ Passwort erfolgreich geändert. Du wirst jetzt abgemeldet…
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert-error">@_error</div>
    }

    <div class="form-grid" style="max-width:420px">
        <label>Aktuelles Passwort</label>
        <input @bind="_current" type="password" class="form-input" autocomplete="current-password" />

        <label>Neues Passwort</label>
        <input @bind="_new1" type="password" class="form-input" autocomplete="new-password" />

        <label>Neues Passwort (Wiederholung)</label>
        <input @bind="_new2" type="password" class="form-input" autocomplete="new-password" />
    </div>

    <div class="form-actions" style="margin-top:1rem">
        <button class="btn-save" @onclick="Save" disabled="@_loading">
            @(_loading ? "Speichern …" : "💾 Passwort speichern")
        </button>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _current = "";
    private string _new1    = "";
    private string _new2    = "";
    private string? _error;
    private bool _loading;
    private bool _success;

    private async Task Save()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_new1) || _new1.Length < 6)
        {
            _error = "Das neue Passwort muss mindestens 6 Zeichen lang sein.";
            return;
        }
        if (_new1 != _new2)
        {
            _error = "Die Passwörter stimmen nicht überein.";
            return;
        }

        var state    = await AuthState!;
        var username = state.User.Identity?.Name ?? "";

        _loading = true;
        StateHasChanged();

        var ok = await AuthService.ChangePasswordAsync(username, _current, _new1);

        if (!ok)
        {
            _error   = "Das aktuelle Passwort ist falsch.";
            _loading = false;
            return;
        }

        _success = true;
        StateHasChanged();

        // Short pause so the success message is visible, then force re-login
        await Task.Delay(2000);
        Nav.NavigateTo("/logout-redirect", forceLoad: true);
    }
}
